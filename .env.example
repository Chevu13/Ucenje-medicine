# ==============================================================
# Učenje medicine — environment variables
# Copy to .env.local and fill in real values. NEVER commit .env.local.
# ==============================================================

# --- Supabase (Project Settings -> API) ---
# Public URL of your Supabase project
NEXT_PUBLIC_SUPABASE_URL=https://YOUR-PROJECT.supabase.co
# Public anon key (safe for the browser; RLS protects data)
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
# Service role key. SERVER ONLY. Used for webhooks, entitlement grants,
# signed file URLs. Never expose to the client.
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# --- Site ---
# Canonical site URL (no trailing slash). Used for SEO, sitemap, redirects.
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# --- Admin demo preview ---
# "true" = /admin opens WITHOUT login so the design can be reviewed.
# Anyone with the URL can view and edit demo data while this is on.
# ⚠️ Remove or set to "false" before launching with real data.
ADMIN_DEMO_MODE=false

# --- Payments ---
# There is NO online payment: buyers leave name, email and Instagram, Darko
# arranges the payment directly and marks orders as paid in the admin panel.
# These variables are unused and kept only for backwards compatibility.
PAYMENT_PROVIDER=manual
PAYMENT_WEBHOOK_SECRET=unused

# --- Optional integrations (hooks are wired, providers are not required) ---
# Transactional email (receipts). Leave empty to log receipts to console.
EMAIL_API_KEY=
EMAIL_FROM="Učenje medicine <no-reply@example.com>"
# Analytics / error monitoring
NEXT_PUBLIC_ANALYTICS_ID=
SENTRY_DSN=
